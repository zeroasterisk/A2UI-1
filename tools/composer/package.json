    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.11.10",
    "localforage": "^1.10.0",
    "lucide-react": "^0.556.0",
    "next": "16.1.5",
    "react": "19.2.1",
    "react-dom": "19.2.1",
